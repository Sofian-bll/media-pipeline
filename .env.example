# Media Pipeline — environment variables
# Copy to .env and fill in your values.

# Watcher
WATCH_POLL_INTERVAL=30
WATCH_EXTENSIONS=mkv,avi,mp4
N8N_WEBHOOK_URL=http://n8n:5678/webhook/watcher

# Worker Pool
MAC_SSH_HOST=100.66.240.74
MAC_SSH_USER=sofian
SSH_KEY_PATH=~/.ssh/id_ed25519
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
CLOUD_PROVIDER=digitalocean
CLOUD_BUCKET=sofian-media-bridge
DO_ENV_FILE=/home/sofian/data/secrets/do-api.env

# Discord notification webhook (required)
DISCORD_WEBHOOK=
